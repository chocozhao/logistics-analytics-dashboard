# OpenAI API Key for natural language query functionality
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Database configuration (used by docker-compose)
POSTGRES_DB=logistics
POSTGRES_USER=reader
POSTGRES_PASSWORD=readonly

# Spring Boot configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/logistics
SPRING_DATASOURCE_USERNAME=reader
SPRING_DATASOURCE_PASSWORD=readonly
SPRING_PROFILES_ACTIVE=dev

# Frontend configuration
VITE_API_URL=http://localhost:8080/api

# Deployment configuration for Render.com/Fly.io
# Uncomment and set these for cloud deployment
# RENDER_DB_URL=
# RENDER_DB_USER=
# RENDER_DB_PASSWORD=
# FLY_APP_NAME=

# Production-specific configuration
# For Render.com deployment, these will be set in Render dashboard
# SPRING_PROFILES_ACTIVE=prod
# CORS_ALLOWED_ORIGINS=https://logistics-frontend.onrender.com
# VITE_API_URL=https://logistics-backend.onrender.com/api